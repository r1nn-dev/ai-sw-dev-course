# ================================================================
# Supabase (Dashboard → Project Settings → API / Database)
# ================================================================

# Project URL — Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co

# Publishable key (2025년부터 새 포맷 `sb_publishable_*`).
# Dashboard → Project Settings → API → API keys → "Publishable key" 복사.
# (구 프로젝트는 `eyJ...` JWT 형태의 "anon public" 키가 여기 들어감 — 호환됨)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxx

# Secret key — 서버 전용, RLS 우회 관리자 권한. 클라이언트 번들 유입 절대 금지.
# Dashboard → Project Settings → API → API keys → "Secret key" (눈 아이콘 클릭해 공개 후 복사)
# (구 프로젝트는 `eyJ...` JWT 형태의 "service_role" 키)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxx

# ================================================================
# Drizzle → Supabase Postgres
# Dashboard → Project Settings → Database → Connection string (URI 탭)
# ================================================================
#
# ⚠️ 2024년부터 "Direct connection" (db.xxxxx.supabase.co) 은 IPv6 전용 —
#    무료 플랜의 일반 가정/사무실 네트워크에서는 DNS 조회 자체가 실패합니다.
#    아래 두 개 모두 반드시 Pooler 호스트(aws-0-*.pooler.supabase.com) 로 지정하세요.

# 앱 런타임 — "Transaction pooler" 탭 (포트 6543). 서버리스 환경 필수.
DATABASE_URL=postgresql://postgres.xxxxx:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# 마이그레이션 전용 — "Session pooler" 탭 (포트 5432). 긴 트랜잭션/DDL용.
#   ※ "Direct connection" 탭이 아님! IPv6 문제로 로컬에서 작동 안 함.
DIRECT_URL=postgresql://postgres.xxxxx:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres
